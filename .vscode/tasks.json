{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "compile and run with file IO",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++17",
                "${file}",
                "-o",
                "${fileBasenameNoExtension}.exe",
                "&&",
                "${fileBasenameNoExtension}.exe",
                "<",
                "input.txt",
                ">",
                "output.txt"
            ],
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/c"]
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}